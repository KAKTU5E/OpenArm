<?xml version='1.0' encoding='utf-8'?>
<robot name="Amigo_Arm" xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:arg name="hardware_plugin" default="cubemars_hardware/CubeMarsSystemHardware"/>
    <xacro:arg name="can_interface" default="can0"/>

    <xacro:include filename="AmigoArmControl.xacro"/>

    <!-- Minimal links -->
    <link name="base_link"/>
    <link name="link1"/>
    <link name="link2"/>
    <link name="link3"/>

    <!-- Minimal joints -->
    <joint name="joint1" type="revolute">
        <parent link="base_link"/>
        <child link="link1"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14159" upper="3.14159" effort="100" velocity="10"/>
    </joint>

    <joint name="joint2" type="revolute">
        <parent link="link1"/>
        <child link="link2"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14159" upper="3.14159" effort="100" velocity="10"/>
    </joint>

    <joint name="joint3" type="revolute">
        <parent link="link2"/>
        <child link="link3"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14159" upper="3.14159" effort="100" velocity="10"/>
    </joint>
        
    <xacro:AmigoArmControl
        hardware_plugin="$(arg hardware_plugin)"
        can_interface="$(arg can_interface)"/>

 </robot>
